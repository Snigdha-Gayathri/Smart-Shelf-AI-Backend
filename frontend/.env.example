# Frontend configuration (safe to expose in browser)
# Copy this file to .env.local and fill values.
#
# Local dev:
# VITE_BACKEND_URL=http://127.0.0.1:8000
#
# Render split deployment:
# VITE_BACKEND_URL=https://your-backend-service.onrender.com
#
# Single-service Render deployment:
# leave VITE_BACKEND_URL empty so the app uses same-origin requests.

VITE_BACKEND_URL=
VITE_CLERK_PUBLISHABLE_KEY=
